    "feats": [
      {
        "name": "Bardic Inspiration (Class)",
        "short": "1 creature receives 1d6 for D20 Test.",
        "hasResource": true,
        "resource": "(3/4) 4/1 Long Rest",
        "details": "As a Bonus Action, you can inspire another creature within 60 ft. that can see or hear you. That creature gains one of your Bardic Inspiration dice (1d6). Once within the next hour, when the creature fails a D20 Test, the creature can roll the Bardic Inspiration die and add the number rolled to the total, potentially turning the failure into a success.",
        "open": false
      },
      {
        "name": "Darkvision (Species)",
        "short": "Yay not a human",
        "hasResource": false,
        "resource": "",
        "details": "",
        "open": false
      },
      {
        "name": "Reactive (Background)",
        "short": "PB to Initiative",
        "hasResource": false,
        "resource": "",
        "details": "Your survival instincts sharpen your reflexes- add PB to Initiative (+2 at Level 1). ",
        "open": false
      },
      {
        "name": "Poison Resilience (Species)",
        "short": "Resilience to poison.",
        "hasResource": false,
        "resource": "",
        "details": "Advantage on saving throws to avoid or end the poisoned condition, plus resistance to poison damage.",
        "open": false
      },
      {
        "name": "Spider Sense (Species)",
        "short": "Buzz Buzz",
        "hasResource": false,
        "resource": "",
        "details": "Extra pair of eyes grants proficiency in Perception. ",
        "open": false
      },
      {
        "name": "Spider Climb (Species)",
        "short": "Upwards and Onwards",
        "hasResource": false,
        "resource": "",
        "details": "Climb speed equal to walking speed. At level 3 you can move up, down, and across vertical surfaces and ceilings while keeping your hands free. ",
        "open": true
      },
      {
        "name": "Arachnid Bite (Species)",
        "short": "Nom Nom",
        "hasResource": false,
        "resource": "",
        "details": "Must grapple target first, then use bonus action for a poisonous bite,. Damage is 1d6+CON modifier. Target risks being poisoned for 1 minute unless they pass a Constitution save (DC = 8 + PB + CON modifier). ",
        "open": false
      },
      {
        "name": "Arachnid Casting (Species)",
        "short": "Pew Pew",
        "hasResource": false,
        "resource": "",
        "details": "Level 1: Mending Cantrip\nLevel 3: Ray of Sickness spell\nLevel 5: Web spell\n\nSpellcasting ability is Charisma. ",
        "open": false
      },
      {
        "name": "Everything is Edible (Background)",
        "short": "Nom Nom x2",
        "hasResource": true,
        "resource": "1/1 Long Rest",
        "details": "Once per long rest, spend 1 hour foraging to craft a number of rations equal to your PB (2 at Level 1). When a creature eats one during a short rest they gain a d4 they can add to one saving throw after rolling but before knowing the outcome. Lasts until long rest. Rations spoil after 24 hours.",
        "open": false
      }
